# ===== ทุกตัวเป็น OPTIONAL — ไม่ต้องใส่ก็ใช้งานได้ =====

# --- โหมด auth (server เลือกอัตโนมัติ) ---
#   1) ตั้ง OAUTH_LOGIN_PASSWORD (+ PUBLIC_URL) -> OAuth 2.1  -> ใช้บน Claude.ai/Cowork web ได้
#   2) ตั้ง MCP_BEARER_TOKEN เพียงอย่างเดียว    -> Bearer    -> เหมาะกับ Claude Code (CLI)
#   3) ไม่ตั้งอะไรเลย                            -> Open
# ถ้าตั้งทั้ง OAuth และ Bearer: web ใช้ OAuth, ส่วน CLI ยังใช้ static token เดิมได้ (ทำงานคู่กัน)

# OAuth login password — รหัสที่จะกรอกในหน้า /login ตอน Claude.ai/Cowork web เชื่อมต่อ
OAUTH_LOGIN_PASSWORD=

# base URL สาธารณะของ server (ใช้เป็น OAuth issuer) เช่น https://xxx.up.railway.app
# บน Railway ไม่ต้องตั้งก็ได้ — server อ่านจาก RAILWAY_PUBLIC_DOMAIN ให้อัตโนมัติ
PUBLIC_URL=

# ล็อก server ด้วย bearer token — ถ้าตั้งค่า ทุก request ต้องส่ง header
#   Authorization: Bearer <token>
# เว้นว่าง = เปิดให้เรียกได้ทุกคน (เหมาะกับ local dev เท่านั้น)
# สร้าง token แบบสุ่ม: python -c "import secrets; print(secrets.token_urlsafe(32))"
MCP_BEARER_TOKEN=

# CoinGecko Demo API key (เพิ่ม rate limit จาก ~10-30 เป็น ~30/นาที)
# สมัครฟรี: https://www.coingecko.com/en/api/pricing
COINGECKO_DEMO_KEY=

# CryptoPanic token (เปิดใช้ tool get_cryptopanic_news)
# สมัครฟรี: https://cryptopanic.com/developers/api/
CRYPTOPANIC_TOKEN=

# พอร์ตสำหรับรัน local (Railway จะ set PORT ให้อัตโนมัติ ไม่ต้องแก้)
PORT=8000
